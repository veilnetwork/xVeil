migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/build/

# Swift Package Manager state — the plugins don't support SPM, so this is just
# Xcode noise; CocoaPods is the integration path (Podfile.lock is tracked).
ios/Runner.xcworkspace/xcshareddata/swiftpm/

# Local, environment-specific config — testnet bootstrap peer sets, dev secrets.
# Never committed (a testnet set is not for the repo). Point the app at a file
# in here via XVEIL_BOOTSTRAP_PEERS.
/local/

# Local dev veil nodes (mined identities, logs, sockets)
.dev-nodes/
/.dev-onion/
/.dev-onion-stream/
/.dev-onion-stream-matrix/
/.dev-mailbox/
/.dev-mailbox-mesh/
/.dev-mailbox-onion/
/assets/prod/obfs4_psk.b64
